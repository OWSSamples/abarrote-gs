# Abarrote-GS - Environment Variables
# Copy to .env.local for local development or configure these in your deployment secret manager.
# Never commit .env.local or real credentials.
#
# Important:
# - Stripe, Clip, Conekta, Telegram and CFDI/PAC merchant credentials are configured
#   inside the app settings and stored server-side.
# - Mercado Pago OAuth platform credentials live here because they identify the
#   platform application used to connect merchant accounts.
# - COGNITO_CLIENT_ID must be an Amazon Cognito App Client WITHOUT
#   a client secret. Browser login will fail with SECRET_HASH if the App Client
#   was created with a secret.
# - The current registration flow expects Cognito username sign-in with email as
#   an alias. It creates an opaque 32-character username and sends email + name
#   as user attributes. Keep self-service sign-up enabled and grant the App Client
#   write access to the email and name attributes.
# - Configure email as the automatically verified attribute. Business phone
#   numbers are stored in the tenant profile and are not used for Cognito SMS.

# Core
DATABASE_URL=
NODE_ENV=development

# AWS Cognito - public browser config exposed by next.config.ts
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1
COGNITO_DOMAIN=
COGNITO_REDIRECT_SIGN_IN=http://localhost:3000/auth/callback
COGNITO_REDIRECT_SIGN_OUT=http://localhost:3000/auth/login
# Optional. Leave empty to use the Cognito-hosted sign-in providers configured
# on the App Client. Example when Microsoft IdP is configured: Microsoft
COGNITO_OAUTH_PROVIDERS=
COGNITO_OAUTH_SCOPES=openid,email,phone
NEXT_PUBLIC_MICROSOFT_TENANT_ID=

# AWS SDK, S3 and SES
# Cognito password recovery and verification emails are configured in the
# Cognito User Pool email settings. For production, connect Cognito to an
# Amazon SES verified identity such as no-reply@opendex.dev or opendex.dev.
# SMTP variables below are only for application-managed transactional emails
# such as receipts, reports and internal security notices.
AWS_REGION=us-east-1
AWS_SES_REGION=us-east-1
AWS_S3_REGION=
# Production only. Prefer the temporary Vercel OIDC role over permanent keys.
# AWS_OIDC_AUDIENCE must match the audience in the IAM trust policy.
AWS_ROLE_ARN=
AWS_OIDC_AUDIENCE=https://vercel.com/opendex-corporation
# Optional local-development fallback. Leave empty in Vercel after OIDC is verified.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Required for tenant receipts and operational evidence. This bucket must not
# allow public access. The application serves these objects through signed URLs.
AWS_S3_PRIVATE_REGION=us-east-1
AWS_S3_PRIVATE_BUCKET=
SES_FROM_EMAIL=
# Optional SES configuration set for bounce, complaint and delivery telemetry.
SES_CONFIGURATION_SET=my-first-configuration-set

# Application URLs
BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Billing platform API. Kiosko sends the current Cognito JWT server-side as
# Authorization: Bearer <token>; do not expose service credentials in the client.
BILLING_API_BASE_URL=https://billing.opendexapis.com

# Internal endpoint authentication
CRON_SECRET=

# Redis / Upstash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# QStash
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Cobrar.io - required when QR webhook flow is enabled; minimum 32 characters
COBRAR_WEBHOOK_SECRET=

# Mercado Pago OAuth platform app
MP_APP_ID=
MP_CLIENT_SECRET=
MP_WEBHOOK_SECRET=

# Optional legacy Mercado Pago access token. Prefer OAuth connection in-app.
MP_ACCESS_TOKEN=

# Encryption - generate a 32-byte hex key and keep it outside source control
OAUTH_ENCRYPTION_KEY=

# Database pool
DB_POOL_MAX=20

# SMTP for application-managed transactional email. Leave SMTP_HOST empty to
# use AWS SES fallback in src/lib/email.ts.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Observability
LOG_LEVEL=info
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
