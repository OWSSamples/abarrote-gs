# ═══════════════════════════════════════════════════════════════
# Abarrote-GS — Environment Variables (Template)
# ═══════════════════════════════════════════════════════════════
# 1. Copy to .env.local:   cp .env.example .env.local
# 2. Fill in values from the corresponding provider dashboards.
# 3. NEVER commit .env.local (already gitignored).
# 4. For prod, store these in Vercel → Settings → Environment Variables.
# Legend: [REQUIRED] = app won't start without it · [OPTIONAL] = enables a feature.

# ── Core ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/abarrote_gs    # [REQUIRED] Neon PostgreSQL
NODE_ENV=development                                              # development | production | test

# ── AWS Cognito (Auth) ────────────────────────────────────────
NEXT_PUBLIC_COGNITO_USER_POOL_ID=   # [REQUIRED] e.g. us-east-2_XXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=      # [REQUIRED] App Client ID
NEXT_PUBLIC_COGNITO_REGION=us-east-2 # [OPTIONAL] AWS region
NEXT_PUBLIC_COGNITO_DOMAIN=         # [REQUIRED for OAuth] e.g. xxx.auth.us-east-2.amazoncognito.com

# ── Microsoft (Azure AD OIDC via Cognito) ─────────────────────
NEXT_PUBLIC_MICROSOFT_TENANT_ID=    # [OPTIONAL] Azure AD tenant ID for MS SSO

# ── AWS SDK (S3 / SES / Cognito Admin) ───────────────────────
AWS_REGION=us-east-2                # [REQUIRED if AWS used]
AWS_ACCESS_KEY_ID=                  # [REQUIRED if AWS used]
AWS_SECRET_ACCESS_KEY=              # [REQUIRED if AWS used]
AWS_S3_BUCKET=                      # [OPTIONAL] for file uploads

# ── App URLs ──────────────────────────────────────────────────
BASE_URL=http://localhost:3000      # [OPTIONAL]
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth / CRON ───────────────────────────────────────────────
CRON_SECRET=                        # [OPTIONAL] secret for /api/cron endpoints

# ── Redis / Upstash ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=             # [OPTIONAL] rate limiting + cache
UPSTASH_REDIS_REST_TOKEN=

# ── QStash (background jobs) ─────────────────────────────────
QSTASH_TOKEN=
QSTASH_URL=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Payments: Stripe ─────────────────────────────────────────
STRIPE_SECRET_KEY=                  # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=              # whsec_...

# ── Payments: Conekta ────────────────────────────────────────
CONEKTA_PRIVATE_KEY=
CONEKTA_WEBHOOK_KEY=
CONEKTA_ENVIRONMENT=sandbox

# ── Payments: Clip ───────────────────────────────────────────
CLIP_API_KEY=
CLIP_SECRET_KEY=
CLIP_SERIAL_NUMBER=
CLIP_WEBHOOK_SECRET=

# ── Payments: MercadoPago ────────────────────────────────────
MP_APP_ID=
MP_CLIENT_SECRET=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ── Telegram Notifications ───────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ── Encryption ────────────────────────────────────────────────
OAUTH_ENCRYPTION_KEY=               # 32-byte hex (generate: openssl rand -hex 32)

# ── CFDI / PAC (Mexican e-invoicing) ─────────────────────────
CFDI_PAC_URL=
CFDI_PAC_USER=
CFDI_PAC_PASSWORD=

# ── Database Pool ─────────────────────────────────────────────
DB_POOL_MAX=10

# ── SMTP (Spacemail / generic) ───────────────────────────────
# If SMTP_HOST is set, sendEmail() uses nodemailer. Otherwise falls back to AWS SES.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Kiosko

# ── Sentry ────────────────────────────────────────────────────
SENTRY_AUTH_TOKEN=                  # source map upload (sntrys_...)

# ── Observability ─────────────────────────────────────────────
LOG_LEVEL=info                      # debug | info | warn | error
# ═══════════════════════════════════════════════════════════════
# Abarrote-GS — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] enable specific features.

# ── Core ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/abarrote_gs    # [REQUIRED] Neon PostgreSQL connection string
NODE_ENV=development                                              # development | production | test

# ── Auth / CRON ───────────────────────────────────────────────
CRON_SECRET=                        # [OPTIONAL] Secret for cron endpoint auth

# ── AWS Cognito (Auth) ────────────────────────────────────────
NEXT_PUBLIC_COGNITO_USER_POOL_ID=   # [REQUIRED] e.g. us-east-1_XXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=      # [REQUIRED] Cognito App Client ID
NEXT_PUBLIC_COGNITO_REGION=us-east-1 # [OPTIONAL] AWS region (default: us-east-1)
NEXT_PUBLIC_COGNITO_DOMAIN=         # [REQUIRED] e.g. your-app.auth.us-east-1.amazoncognito.com

# ── Redis / Upstash ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=             # [OPTIONAL] Upstash Redis REST URL
UPSTASH_REDIS_REST_TOKEN=           # [OPTIONAL] Upstash Redis REST token

# ── QStash (background jobs) ─────────────────────────────────
QSTASH_TOKEN=                       # [OPTIONAL] QStash API token
QSTASH_CURRENT_SIGNING_KEY=         # [OPTIONAL] Current webhook signing key
QSTASH_NEXT_SIGNING_KEY=            # [OPTIONAL] Next webhook signing key

# ── Payment: Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY=                  # [OPTIONAL] sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=              # [OPTIONAL] whsec_...

# ── Payment: Conekta ─────────────────────────────────────────
CONEKTA_PRIVATE_KEY=                # [OPTIONAL] key_...
CONEKTA_WEBHOOK_KEY=                # [OPTIONAL] Webhook signing key
CONEKTA_ENVIRONMENT=sandbox         # sandbox | production

# ── Payment: Clip ────────────────────────────────────────────
CLIP_API_KEY=                       # [OPTIONAL] Clip API key
CLIP_SECRET_KEY=                    # [OPTIONAL] Clip secret key
CLIP_SERIAL_NUMBER=                 # [OPTIONAL] Terminal serial number
CLIP_WEBHOOK_SECRET=                # [OPTIONAL] Webhook secret

# ── Payment: MercadoPago ─────────────────────────────────────
MP_APP_ID=                          # [OPTIONAL] MercadoPago application ID
MP_CLIENT_SECRET=                   # [OPTIONAL] Client secret
MP_ACCESS_TOKEN=                    # [OPTIONAL] Access token (TEST or PROD)
MP_WEBHOOK_SECRET=                  # [OPTIONAL] Webhook signature secret

# ── AWS S3 (file uploads) ────────────────────────────────────
AWS_REGION=                         # [OPTIONAL] e.g. us-east-1
AWS_ACCESS_KEY_ID=                  # [OPTIONAL]
AWS_SECRET_ACCESS_KEY=              # [OPTIONAL]
AWS_S3_BUCKET=                      # [OPTIONAL] S3 bucket name

# ── Telegram Notifications ───────────────────────────────────
TELEGRAM_BOT_TOKEN=                 # [OPTIONAL] Bot token from @BotFather
TELEGRAM_CHAT_ID=                   # [OPTIONAL] Chat/group ID
TELEGRAM_WEBHOOK_SECRET=            # [OPTIONAL] Webhook verification secret

# ── Encryption ────────────────────────────────────────────────
OAUTH_ENCRYPTION_KEY=               # [OPTIONAL] 32-byte hex key for OAuth token encryption

# ── CFDI / PAC (Electronic Invoicing) ────────────────────────
CFDI_PAC_URL=                       # [OPTIONAL] PAC service URL
CFDI_PAC_USER=                      # [OPTIONAL] PAC username
CFDI_PAC_PASSWORD=                  # [OPTIONAL] PAC password

# ── Database Pool ─────────────────────────────────────────────
DB_POOL_MAX=10                      # [OPTIONAL] Max database pool connections

# ── App URLs ──────────────────────────────────────────────────
BASE_URL=http://localhost:3000      # [OPTIONAL] Application base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000 # [OPTIONAL] Public app URL
# VERCEL_URL and VERCEL_PROJECT_PRODUCTION_URL are set automatically by Vercel

# ── Observability ─────────────────────────────────────────────
LOG_LEVEL=info                      # [OPTIONAL] debug | info | warn | error

# ── SMTP interno / Spacemail / cualquier IMAP-SMTP ──
# Si SMTP_HOST está presente, sendEmail() usa nodemailer (interno).
# Caso contrario, hace fallback a AWS SES.
SMTP_HOST="mail.spacemail.com"
SMTP_PORT="465"
SMTP_SECURE="true"          # true=SSL implícito (465), false=STARTTLS (587)
SMTP_USER="no-reply@tu-dominio.com"
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="no-reply@tu-dominio.com"
SMTP_FROM_NAME="Tu Negocio"
