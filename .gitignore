# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Bun is the canonical package manager — disallow npm/yarn/pnpm lockfiles
package-lock.json
yarn.lock
pnpm-lock.yaml

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
.env.local.bak.*
*.env
secrets/
*.pem
*.key
*-key.json
service-account*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

playwright-report/
test-results/
.env*.local
.vscode/mcp.json

# Sentry Config File
.env.sentry-build-plugin
